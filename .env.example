# ai-approval-workflow public example configuration.
# Copy this file to .env in a private deployment. Never commit real secrets.

# Runtime mode: development, staging, or production.
AAW_APP_ENV=development

# Bind address for the local FastAPI process. Use localhost behind a reverse proxy in production.
AAW_BIND_HOST=127.0.0.1

# Bind port for the local FastAPI process.
AAW_BIND_PORT=8787

# Public URL used to generate mobile approval links. Example: https://approval.example.com
AAW_PUBLIC_BASE_URL=http://127.0.0.1:8787

# SQLite database path. Keep production databases outside the repository.
AAW_DATABASE_PATH=./data/ai-approval-workflow.db

# Directory containing workflow YAML files. Use ./examples for local demos only.
AAW_WORKFLOWS_DIR=./examples

# Enable cron scheduling. Keep false for local manual testing.
AAW_SCHEDULER_ENABLED=false

# OpenAI-compatible API base URL. Leave empty to use deterministic fallback summaries.
AAW_AI_BASE_URL=

# OpenAI-compatible API key. Keep empty in public files.
AAW_AI_API_KEY=

# AI model name used by the OpenAI-compatible endpoint.
AAW_AI_MODEL=gpt-4.1-mini

# AI request timeout in seconds. Increase this for longer source material or slower models.
AAW_AI_TIMEOUT_SECONDS=30

# Whether to generate deterministic local fallback text when no AI endpoint/key is configured.
# Set to false in production if raw collected material should never be sent as a fallback.
AAW_AI_FALLBACK_ENABLED=true

# Notification webhook URL. Example: https://notify.example.com/webhook
AAW_NOTIFICATION_WEBHOOK_URL=

# Optional bearer token added as Authorization: Bearer <token> for the notification webhook.
AAW_NOTIFICATION_BEARER_TOKEN=

# Logical channel name passed to the notification adapter.
AAW_NOTIFICATION_CHANNEL=ops-default

# Source name included in outbound notification payloads.
AAW_NOTIFICATION_SOURCE=ai-approval-workflow

# Default mobile approval expiration in seconds.
AAW_APPROVAL_DEFAULT_TTL_SECONDS=1800

# Snooze duration in seconds for a snooze decision.
AAW_SNOOZE_SECONDS=1800

# Root-managed action allowlist YAML. Leave empty unless command_check / queued_action is installed.
AAW_ACTIONS_CONFIG_PATH=

# Directory where approved action JSON requests are queued. Keep production queues outside git.
AAW_ACTION_QUEUE_DIR=./data/actions
